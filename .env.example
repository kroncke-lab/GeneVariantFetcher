# Required for PubMed / NCBI E-utilities.
NCBI_EMAIL=you@example.com

# Required: configure at least one LLM provider that matches config/settings.py.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_AI_API_KEY=
# AZURE_AI_API_BASE=

# Recommended for higher NCBI rate limits.
# NCBI_API_KEY=

# Recommended for publisher full-text coverage.
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
# SPRINGER_API_KEY=
# WILEY_API_KEY=

# Optional model-routing experiments.
# GPT54_DEPLOYMENT=
# DEEPSEEK_DEPLOYMENT=
# EARLY_DEBATE_MODELS=
# DEEPSEEK_RPM=4

# Optional per-stage reasoning effort for OpenAI-style reasoning models
# (gpt-5 / o-series). One of: minimal | low | medium | high. Unset = provider
# default (current behavior). Silently ignored for models without an effort
# knob (Anthropic, Grok, Kimi) — set those tiers to a gpt-5/o-series model for
# the knob to take effect. Change one tier at a time and re-score with
# scripts/run_recall_suite.py before keeping a non-default value.
# TIER2_REASONING_EFFORT=minimal      # Tier 2 relevance: high-volume; 'minimal' saves cost
# TIER3_REASONING_EFFORT=medium       # Tier 3 extraction + adjudication: the recall/MAE lever
# TABLE_ROUTER_REASONING_EFFORT=low   # table classification
# VISION_REASONING_EFFORT=medium      # figure/pedigree vision models (chat + Responses API)
