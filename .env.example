# Required for PubMed / NCBI E-utilities.
NCBI_EMAIL=brett.kroncke@gmail.com

# Required: configure at least one LLM provider that matches config/settings.py.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_AI_API_KEY=
# AZURE_AI_API_BASE=

# Recommended for higher NCBI rate limits.
# NCBI_API_KEY=

# Recommended for publisher full-text coverage.
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
# SPRINGER_API_KEY=
# WILEY_API_KEY=

# Institutional EZproxy — routes Cloudflare-blocked publishers (Wiley/Karger/Sage)
# through the library's subscriber IP so they return licensed full text +
# supplements without a CF challenge. Set ONE; needs a valid EZproxy session
# cookie loaded (log into the proxy once in Chrome). See
# docs/RECALL_REFRESH_RUNBOOK.md and verify with scripts/check_ezproxy.py.
# NOTE: the live Vanderbilt login host is the *login.* subdomain. EZproxy uses
# host-rewriting with a wildcard cert (*.proxy.library.vanderbilt.edu) that does
# NOT cover the bare apex, so "https://proxy.library.vanderbilt.edu/..." throws a
# cert error — you must use login.proxy.library.vanderbilt.edu (verified live
# 2026-06-08 with a VUMC.org-email SSO session).
# GVF_EZPROXY_PREFIX="https://login.proxy.library.vanderbilt.edu/login?url="
# GVF_EZPROXY_HOST="login.proxy.library.vanderbilt.edu"
# GVF_EZPROXY_ALL=1   # optional: proxy ALL publisher URLs, not just CF-blocked
#
# Cookie source for authenticated recovery. By default GVF reads your logged-in
# Chrome session via browser_cookie3. Newer Chrome builds lock the cookie key to
# Chrome (browser_cookie3 fails with "Unable to get key"), and reading Chrome
# never works headless / through an agent. In that case export the proxy cookies
# from Chrome to a Netscape cookies.txt (a "Get cookies.txt LOCALLY" extension)
# and point GVF at it — this bypasses the Keychain entirely and is honored
# everywhere cookies are loaded (preflight probe + paywall recovery):
# GVF_COOKIE_FILE=~/gvf-cookies.txt

# Institutional-access preflight (gvf-run). A full-dataset run (source recovery
# on, no --pmid-file) HALTS before harvesting if a LIVE paywall-access check fails
# — so it can't silently harvest abstract-only and still report success. Override
# a block for a deliberate partial run with `--allow-degraded-institutional`; a
# fast/calibration run (`--no-source-recovery` / `--pmid-file`) skips the check.
# GVF_PREFLIGHT_SKIP=1              # skip the live check entirely (CI/automation; access NOT verified)
# GVF_PREFLIGHT_DOI=10.1111/jce.14865  # canary Wiley DOI the probe routes through EZproxy
# GVF_PREFLIGHT_TIMEOUT_S=45        # probe network timeout + per-domain cookie-load cap
# GVF_MAX_ABSTRACT_ONLY_RATIO=0.85  # post-run audit flags the run degraded at/above this stub ratio
# GVF_MAX_SUPPLEMENTS=40   # per-paper supplement cap (T7; default 40)

# Optional network resilience (default: off). On hosts whose IPv6 path to
# external services blackholes, TCP connections establish but reads hang forever
# because most HTTP calls set no read timeout. Enable these to fail fast + retry
# instead of hanging. NOTE: httpx-based LLM clients set their own timeouts and
# are unaffected by GVF_SOCKET_TIMEOUT.
# GVF_FORCE_IPV4=1          # resolve hostnames to IPv4 (AF_INET) only
# GVF_SOCKET_TIMEOUT=120    # process-wide default socket timeout, seconds

# Optional model-routing configuration.
# Azure-first routine routing plus the canonical default-on GPT-5.6 final
# per-paper sniff test (Step 3.8). Sonnet/Opus remain optional exception queues.
# Foundry OpenAI-compatible base (recommended for gpt-5.6-sol):
#   AZURE_AI_API_BASE=https://MAGen-API.services.ai.azure.com/openai/v1
#   deployment_name = gpt-5.6-sol  →  PAPER_FINAL_CHECK_MODEL=azure_ai/gpt-5.6-sol
# Portal project URLs (.../api/projects/<project>) are for the SDK, not inference.
# MODEL_PROVIDER=azure
# AZURE_AI_API_VERSION=v1
# AZURE_DEPLOYMENT_GPT54=gpt-5.4
# AZURE_DEPLOYMENT_KIMI=Kimi-K2.6-1
# AZURE_DEPLOYMENT_GROK=grok-4.3
# AZURE_DEPLOYMENT_DEEPSEEK=DeepSeek-V4-Pro
# AZURE_DEPLOYMENT_GPT56_SOL=gpt-5.6-sol  # used only by Step 3.8 by default
# TIER2_MODEL=azure_ai/gpt-5.4
# TIER2_MAX_TOKENS=8192
# TABLE_ROUTER_MODEL=azure_ai/Kimi-K2.6-1
# TIER3_MODELS=azure_ai/grok-4.3
# TIER3_ADJUDICATOR_MODELS=azure_ai/gpt-5.4
# EARLY_DEBATE_MODELS=azure_ai/gpt-5.4,azure_ai/DeepSeek-V4-Pro,azure_ai/Kimi-K2.6-1
# PAPER_FINAL_CHECK_ENABLED=true
# PAPER_FINAL_CHECK_MODEL=azure_ai/gpt-5.6-sol  # optional direct override
# PAPER_FINAL_CHECK_REASONING_EFFORT=xhigh      # canonical max-thinking default
# FINAL_ADJUDICATOR_MODELS=anthropic/claude-sonnet-5  # optional exception queue
# FINAL_ARBITER_MODEL=anthropic/claude-opus-4-8       # optional hard-case queue
# LLM_REQUEST_TIMEOUT_S=300
# LLM_RETRY_ATTEMPTS=2
# GPT54_DEPLOYMENT=
# DEEPSEEK_DEPLOYMENT=
# DEEPSEEK_RPM=4

# Optional per-stage reasoning effort for OpenAI-style reasoning models
# (gpt-5 / o-series / gpt-5.6). One of: none | minimal | low | medium | high |
# xhigh (max thinking on gpt-5.6; 'max' is accepted as an alias). Unset =
# provider default. Silently ignored for models without an effort knob
# (Anthropic, Grok, Kimi) — set those tiers to a gpt-5/o-series model for the
# knob to take effect. Change one tier at a time and re-score with
# scripts/run_recall_suite.py before keeping a non-default value.
# TIER2_REASONING_EFFORT=minimal      # Tier 2 relevance: high-volume; 'minimal' saves cost
# TIER3_REASONING_EFFORT=medium       # Tier 3 extraction + adjudication: the recall/MAE lever
# TABLE_ROUTER_REASONING_EFFORT=low   # table classification
# VISION_REASONING_EFFORT=medium      # figure/pedigree vision models (chat + Responses API)
# PAPER_FINAL_CHECK_REASONING_EFFORT=xhigh  # Step 3.8 canonical default
# FINAL_ADJUDICATOR_REASONING_EFFORT=       # only for an OpenAI-style override
# FINAL_ARBITER_REASONING_EFFORT=           # only for an OpenAI-style override
